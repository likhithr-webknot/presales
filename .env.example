# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://presales:presales@localhost:5432/presales   # REQUIRED

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379                                        # REQUIRED

# ─── Storage (MinIO / S3-compatible) ─────────────────────────────────────────
STORAGE_ENDPOINT=http://localhost:9000                                  # REQUIRED
STORAGE_ACCESS_KEY=minioadmin                                           # REQUIRED
STORAGE_SECRET_KEY=minioadmin                                           # REQUIRED
STORAGE_BUCKET_UPLOADS=presales-uploads                                # OPTIONAL (default shown)
STORAGE_BUCKET_ARTIFACTS=presales-artifacts                            # OPTIONAL
STORAGE_BUCKET_TEMPLATES=presales-templates                            # OPTIONAL
STORAGE_BUCKET_EXPORTS=presales-exports                                # OPTIONAL
STORAGE_PRESIGNED_URL_TTL_HOURS=24                                     # OPTIONAL (default: 24)

# ─── Auth (Google SSO) ───────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=                                                       # REQUIRED
GOOGLE_CLIENT_SECRET=                                                   # REQUIRED
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback          # REQUIRED
JWT_SECRET=change-me-min-32-chars-long-please                          # REQUIRED (min 32 chars)
JWT_EXPIRY=7d                                                           # OPTIONAL (default: 7d)
ALLOWED_GOOGLE_DOMAINS=                                                 # OPTIONAL (e.g. webknot.in — restricts login to this domain)

# ─── LLM Providers (used by Python ai-service, NOT Node backend) ────────────
OPENAI_API_KEY=                                                         # REQUIRED
ANTHROPIC_API_KEY=                                                      # REQUIRED
GEMINI_API_KEY=                                                         # REQUIRED

# ─── AI Service (internal service communication) ────────────────────────────
AI_SERVICE_URL=http://ai-service:8000                                   # REQUIRED (docker: auto-set; local: http://localhost:8001)
AI_INTERNAL_SECRET=change-me-in-prod-min-32-chars                      # REQUIRED — shared secret for Node↔Python auth

# ─── Email (Nodemailer) ──────────────────────────────────────────────────────
EMAIL_SMTP_HOST=smtp.gmail.com                                          # REQUIRED
EMAIL_SMTP_PORT=587                                                     # REQUIRED
EMAIL_SMTP_USER=                                                        # REQUIRED
EMAIL_SMTP_PASS=                                                        # REQUIRED
EMAIL_FROM=Presales Orchestrator <presales@webknot.in>                 # REQUIRED — fully configurable
EMAIL_ENABLED=true                                                      # OPTIONAL (set false to log instead of send in dev)

# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=development                                                    # REQUIRED
PORT=3000                                                               # OPTIONAL (default: 3000)
FRONTEND_URL=http://localhost:5173                                      # REQUIRED (CORS + email links)
API_BASE_URL=http://localhost:3000/api                                  # REQUIRED

# ─── Feature Config ──────────────────────────────────────────────────────────
COMPLIANCE_VARIANCE_THRESHOLD=1.0     # OPTIONAL — stddev threshold for high-variance compliance flag
GATE_REMINDER_HOURS=24                # OPTIONAL — hours before reminder email fires to AM
MIN_REVIEWER_COUNT=1                  # OPTIONAL — minimum approvers required per gate
MAX_UPLOAD_SIZE_MB=50                 # OPTIONAL — max file size for RFP uploads
LLM_OUTPUT_CACHE_TTL_SECONDS=3600    # OPTIONAL — Redis cache TTL for LLM outputs

# ─── Adapters — toggle stub vs real ─────────────────────────────────────────
# Set to 'real' only when the external system is built and ready.
# 'stub' is safe default for all environments until then.
MEETMINDS_ADAPTER=stub                # OPTIONAL: 'stub' | 'real' (default: stub)
MEETMINDS_API_URL=                    # REQUIRED if MEETMINDS_ADAPTER=real
MEETMINDS_API_KEY=                    # REQUIRED if MEETMINDS_ADAPTER=real
PRICING_ADAPTER=stub                  # OPTIONAL: 'stub' | 'real' (default: stub)
PRICING_API_URL=                      # REQUIRED if PRICING_ADAPTER=real
PRICING_API_KEY=                      # REQUIRED if PRICING_ADAPTER=real
KB_ADAPTER=stub                       # OPTIONAL: 'stub' | 'real' (default: stub)
